S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=senna-artifacts
S3_PREFIX=senna-neuro

OUTBOX_DIR=/artifacts/outbox
STATE_FILE=/artifacts/uploader_state.json

UPLOAD_BATCH_EPOCHS=5
UPLOAD_MAX_BATCH_FILES=20
UPLOAD_FLUSH_INTERVAL_SEC=45
UPLOAD_POLL_INTERVAL_SEC=5
UPLOAD_MIN_FILE_AGE_SEC=10
