{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {
          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        },
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "peak" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 4] } },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mean" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "description": "Current, running mean, and peak active neurons ratio. If current consistently exceeds mean, the network is becoming more active over time. Peak shows the highest burst ever observed.",
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_active_neurons_ratio",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "senna_mean_active_neurons_ratio",
          "legendFormat": "mean",
          "refId": "B"
        },
        {
          "expr": "senna_max_active_neurons_ratio",
          "legendFormat": "peak",
          "refId": "C"
        }
      ],
      "title": "Active Neurons: Current / Mean / Peak",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "mean" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "description": "Instantaneous spikes per tick vs running mean. Divergence indicates the network is entering a different activity regime. Sustained high spikes without accuracy improvement suggests runaway excitation.",
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_spikes_per_tick",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "senna_mean_spikes_per_tick",
          "legendFormat": "mean",
          "refId": "B"
        }
      ],
      "title": "Spikes Per Tick: Current / Mean",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "description": "Cumulative spikes emitted over time. A healthy training run shows steady growth; plateaus mean the network has gone silent, while sudden jumps indicate bursts of activity.",
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_spikes_total",
          "legendFormat": "total spikes",
          "refId": "A"
        }
      ],
      "title": "Cumulative Spikes",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "description": "Total simulation ticks processed. Compare with training progress to detect stalls. Rate of growth reflects effective simulation throughput.",
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_ticks_total",
          "legendFormat": "total ticks",
          "refId": "A"
        }
      ],
      "title": "Cumulative Ticks",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "description": "Training throughput in samples per second. Drops may indicate heavier network activity (more spikes to process), structural plasticity rebuilds, or host resource contention.",
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_training_samples_per_sec",
          "legendFormat": "samples/sec",
          "refId": "A"
        }
      ],
      "title": "Training Throughput",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "net change/5m" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 10 },
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "description": "Synapse count alongside net structural change (sprouted minus pruned) over 5 minutes. A stable synapse count with non-zero delta means pruning and sprouting are balanced; monotonic decline means the network is losing connectivity.",
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "senna_synapse_count",
          "legendFormat": "synapse count",
          "refId": "A"
        },
        {
          "expr": "increase(senna_sprouted_total[5m]) - increase(senna_pruned_total[5m])",
          "legendFormat": "net change/5m",
          "refId": "B"
        }
      ],
      "title": "Synapse Topology",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "senna",
    "health"
  ],
  "templating": {
    "list": []
  },
