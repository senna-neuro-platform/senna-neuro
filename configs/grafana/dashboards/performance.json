{
  "uid": "senna-performance",
  "title": "Performance",
  "timezone": "browser",
  "schemaVersion": 37,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ticks per Second",
      "datasource": { "type": "prometheus", "uid": "senna-prom" },
      "targets": [
        { "expr": "senna_ticks_per_second", "legendFormat": "tps", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tick Duration (p50/p95)",
      "datasource": { "type": "prometheus", "uid": "senna-prom" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(senna_tick_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(senna_tick_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "Tick Duration Histogram",
      "datasource": { "type": "prometheus", "uid": "senna-prom" },
      "targets": [
        {
          "expr": "sum(rate(senna_tick_duration_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "show": true }, "color": { "mode": "scheme" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory Usage (core)",
      "datasource": { "type": "prometheus", "uid": "senna-prom" },
      "targets": [
        { "expr": "senna_memory_bytes / 1024 / 1024", "legendFormat": "MiB", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
